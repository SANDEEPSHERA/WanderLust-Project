# Copy to .env and fill in values. Default app port is 8080 (see app.js).
PORT=8080

# MongoDB — local or Atlas
MONGODB_URI=mongodb://127.0.0.1:27017/wanderlust

# Session (change in production)
SESSION_SECRET=mysupersecretkey_change_this_in_production

# Cloudinary (listing images)
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# Mapbox (maps + geocoding in controllers/listings.js)
MAPBOX_API_KEY=your_mapbox_api_key_here
