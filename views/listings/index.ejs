<% layout("/layouts/boilerplate") %>

<div class="container-fluid mt-0">

  <!-- Search, filters, tax -->
  <div class="row g-3 mb-4 p-3 bg-light rounded mx-2 mt-3">
    
    <!-- Search Bar -->
    <div class="col-md-4">
      <form method="GET" action="/listings" class="d-flex">
        <input 
          type="text" 
          name="search" 
          class="form-control me-2" 
          placeholder="Search by location or title..."
          value="<%= typeof search !== 'undefined' ? search : '' %>"
        >
        <button type="submit" class="btn btn-primary">Search</button>
      </form>
    </div>

    <!-- Filter by Country -->
    <div class="col-md-3">
      <form method="GET" action="/listings">
        <select name="country" class="form-select" onchange="this.form.submit()">
          <option value="">All Countries</option>
          <option value="India" <%= typeof country !== 'undefined' && country === 'India' ? 'selected' : '' %>>India</option>
          <option value="USA" <%= typeof country !== 'undefined' && country === 'USA' ? 'selected' : '' %>>USA</option>
          <option value="UK" <%= typeof country !== 'undefined' && country === 'UK' ? 'selected' : '' %>>UK</option>
          <option value="Australia" <%= typeof country !== 'undefined' && country === 'Australia' ? 'selected' : '' %>>Australia</option>
          <option value="Japan" <%= typeof country !== 'undefined' && country === 'Japan' ? 'selected' : '' %>>Japan</option>
        </select>
      </form>
    </div>

    <!-- Price Range Filter -->
    <div class="col-md-3">
      <form method="GET" action="/listings">
        <select name="priceRange" class="form-select" onchange="this.form.submit()">
          <option value="">Any Price</option>
          <option value="0-5000" <%= typeof priceRange !== 'undefined' && priceRange === '0-5000' ? 'selected' : '' %>>Under ₹5,000</option>
          <option value="5000-10000" <%= typeof priceRange !== 'undefined' && priceRange === '5000-10000' ? 'selected' : '' %>>₹5,000 - ₹10,000</option>
          <option value="10000+" <%= typeof priceRange !== 'undefined' && priceRange === '10000+' ? 'selected' : '' %>>Above ₹10,000</option>
        </select>
      </form>
    </div>

    <!-- Tax toggle -->
    <div class="col-md-2 d-flex align-items-center justify-content-between">
      <span class="fw-semibold">Include Taxes</span>
      <div class="form-check form-switch">
        <input 
          class="form-check-input" 
          type="checkbox" 
          id="taxSwitch"
          <%= typeof includeTaxes !== 'undefined' && includeTaxes ? 'checked' : '' %>
          onchange="toggleTaxes(this.checked)"
        >
        <label class="form-check-label" for="taxSwitch"></label>
      </div>
    </div>
  </div>

  <!-- Map -->
  <div class="row mb-4 mx-2">
    <div class="col-12">
      <div id="map" style="height: 400px; width: 100%; border-radius: 10px;"></div>
    </div>
  </div>

  <!-- LISTINGS GRID -->
  <div class="row mx-2">
    <h3 class="mb-4"><%= typeof search !== 'undefined' && search ? 'Search Results' : 'All Listings' %></h3>

    <% if(allListings.length === 0) { %>
      <div class="alert alert-warning">No listings found!</div>
    <% } %>

    <% for(let listing of allListings) { %>
      <div class="col-md-4 mb-4">
        <a href="/listings/<%= listing._id %>" class="listing-link">
          <div class="card h-100 shadow-sm">
            <!-- IMAGE -->
            <% if(listing.image && listing.image.url) { %>
            <img 
              src="<%= listing.image.url %>" 
              class="card-img-top" 
              alt="listing_image"
              style="height: 250px; object-fit: cover;"
            >
            <% } else { %>
            <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 250px;">
              <span class="text-white">No Image Available</span>
            </div>
            <% } %>

            <div class="card-body">
              <h5 class="card-title"><%= listing.title %></h5>
              <p class="card-text">
                <strong>₹ <%= includeTaxes ? (listing.price * 1.18).toFixed(0) : listing.price %> / night</strong>
                <% if(includeTaxes) { %>
                  <small class="text-success">(incl. 18% GST)</small>
                <% } else { %>
                  <small class="text-muted">(excl. taxes)</small>
                <% } %>
                <br>
                <%= listing.location %>, <%= listing.country %>
              </p>
            </div>
          </div>
        </a>
      </div>
    <% } %>
  </div>

</div>

