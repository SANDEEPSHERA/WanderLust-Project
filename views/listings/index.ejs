    // Tax toggle function
    function toggleTaxes(include) {
      const url = new URL(window.location);
      if (include) {
        url.searchParams.set('includeTaxes', 'true');
      } else {
        url.searchParams.delete('includeTaxes');
      }
      window.location.href = url.toString();
    }
  } else {
    // Show message if API key not configured
    document.getElementById('map').innerHTML = '<div style="display: flex; align-items: center; justify-content: center; height: 100%; background: #f0f0f0; border-radius: 10px;"><p style="color: #666; font-size: 16px;">Map not loaded - add your Mapbox API key to the .env file</p></div>';
  }
</script>
