<% layout("/layouts/boilerplate") %>

<div class="container mt-5">

    <h2 class="mb-4 fw-bold">Edit Listing</h2>

    <form method="POST" action="/listings/<%= listing._id %>?_method=PUT"
         novalidate
         class="needs-validation"
         enctype="multipart/form-data">

        <!-- Title -->
        <div class="mb-3">
            <label class="form-label fw-semibold">Title</label>
            <input 
                name="listing[title]" 
                value="<%= listing.title %>" 
                class="form-control shadow-sm"
                required
            >
            <div class="valid-feedback">Looks good!</div>
        </div>

        <!-- Description -->
        <div class="mb-3">
            <label class="form-label fw-semibold">Description</label>
            <textarea 
                name="listing[description]" 
                class="form-control shadow-sm"
                required
                rows="3"
            ><%= listing.description %></textarea>
            <div class="invalid-feedback">Please enter a description</div>
        </div>

        <!-- Image Upload -->
        <div class="mb-3">
            <label class="form-label fw-semibold">Upload New Image (Optional)</label>
            <input 
                name="listing[image]" 
                type="file"
                accept="image/*"
                class="form-control shadow-sm"
                id="editImagePreviewInput"
                onchange="previewEditImage(event)"
            >
            <div class="mt-2">
                <p class="text-muted mb-2">Current Image:</p>
                <img id="currentImage" src="<%= listing.image.url %>" style="max-width: 100%; border-radius: 8px;" class="shadow-sm mb-3" />
                <img id="editImagePreview" src="#" style="max-width: 100%; border-radius: 8px; display: none;" class="shadow-sm" />
            </div>
        </div>

        <!-- Price -->
        <div class="mb-3">
            <label class="form-label fw-semibold">Price</label>
            <input 
                name="listing[price]" 
                value="<%= listing.price %>" 
                type="number" 
                class="form-control shadow-sm"
                required
            >
            <div class="invalid-feedback">Please enter a valid price</div>
        </div>

        <!-- Country -->
        <div class="mb-3">
            <label class="form-label fw-semibold">Country</label>
            <input 
                name="listing[country]" 
                value="<%= listing.country %>" 
                class="form-control shadow-sm"
                required
            >
            <div class="invalid-feedback">Please enter a country</div>
        </div>

        <!-- Location -->
        <div class="mb-4">
            <label class="form-label fw-semibold">Location</label>
            <input 
                name="listing[location]" 
                value="<%= listing.location %>" 
                class="form-control shadow-sm"
                required
            >
            <div class="invalid-feedback">Please enter a location</div>
        </div>

        <!-- Buttons -->
        <div class="d-flex gap-3">
            <button class="btn btn-danger px-4">
                Update Listing
            </button>

            <a href="/listings" class="btn btn-secondary px-4">
                Cancel
            </a>
        </div>

    </form>

</div>

<script src="/js/script.js"></script>
<script>
  // Edit page image preview
  function previewEditImage(event) {
    const file = event.target.files[0];
    if (file) {
      const reader = new FileReader();
      reader.onload = function(e) {
        const currentImg = document.getElementById('currentImage');
        const previewImg = document.getElementById('editImagePreview');
        currentImg.style.display = 'none';
        previewImg.src = e.target.result;
        previewImg.style.display = 'block';
      }
      reader.readAsDataURL(file);
    }
  }
</script>